# Copy to scraper/.env and fill in. Loaded automatically by `uv run scrape`.
# In GitHub Actions these come from repo secrets instead (see .github/workflows).

# ── Supabase (write target) ─────────────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# SECRET key (sb_secret_…) — bypasses RLS to upsert. Server-only; never commit.
# Supabase dashboard → Project Settings → API Keys → Secret keys.
SUPABASE_SECRET_KEY=
