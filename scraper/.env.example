# Copy to scraper/.env and fill in. Loaded automatically by `uv run scrape`.
# In GitHub Actions these come from repo secrets instead (see .github/workflows).

# ── Reddit auth (exactly one required) ─────────────────────────────────────
# Option A — session cookie (from browser DevTools → Network tab → any reddit.com
#   request → Request Headers → Cookie). Copy the entire Cookie: header value.
REDDIT_COOKIE=

# Option B — bearer token (from browser DevTools → Network tab → any
#   oauth.reddit.com request → Request Headers → Authorization: Bearer <token>).
#   Supersedes REDDIT_COOKIE if both are set.
REDDIT_TOKEN=

# ── Supabase (write target) ─────────────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# SECRET key (sb_secret_…) — bypasses RLS to upsert. Server-only; never commit.
# Supabase dashboard → Project Settings → API Keys → Secret keys.
SUPABASE_SECRET_KEY=
