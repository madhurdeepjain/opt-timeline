# Copy to dashboard/.env.local. These are inlined into the client bundle at
# build time (NEXT_PUBLIC_*), so use ONLY the publishable key here — never the
# secret key. The tables are read-only to this key via RLS.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# PUBLISHABLE key (sb_publishable_…) — the 2025+ replacement for the anon key.
# Supabase dashboard → Project Settings → API Keys → Publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
